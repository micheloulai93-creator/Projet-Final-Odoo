<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- EXPORT 2 : Synthèse des coûts                                 -->
    <!-- ============================================================ -->

    <record id="action_wizard_export_couts" model="ir.actions.act_window">
        <field name="name">Export Excel - Coûts maintenance</field>
        <field name="res_model">it.wizard.export.couts</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_it_intervention"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <record id="view_wizard_export_couts_form" model="ir.ui.view">
        <field name="name">wizard.export.couts.form</field>
        <field name="model">it.wizard.export.couts</field>
        <field name="arch" type="xml">
            <form string="Export Coûts">
                <sheet>
                    <div class="oe_title">
                        <h1>Export Excel - Synthèse des coûts de maintenance</h1>
                    </div>

                    <group>
                        <field name="annee" required="1"/>
                        <field name="par_mois"/>
                    </group>

                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/>
                        <span invisible="not par_mois">Affichage détaillé par mois et par équipement.</span>
                        <span invisible="par_mois">Affichage par équipement seulement (total annuel).</span>
                    </div>

                    <group string="Fichier" invisible="not export_done">
                        <field name="filename"/>
                        <field name="file_datas" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_export" string="Exporter" type="object" class="btn-primary"
                            invisible="export_done"/>
                    <button name="action_download" string="Télécharger" type="object" class="btn-success"
                            invisible="not export_done"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>