<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_equipement_affectation_tree" model="ir.ui.view">
        <field name="name">it.equipement.affectation.tree</field>
        <field name="model">it.equipement.affectation</field>
        <field name="arch" type="xml">
            <list string="Historique des affectations" create="0" edit="0" delete="0">
                <field name="date_affectation"/>
                <field name="equipement_id"/>
                <field name="ancien_employe_id"/>
                <field name="nouvel_employe_id"/>
                <field name="ancien_department_id"/>
                <field name="nouveau_department_id"/>
                <field name="motif"/>
                <field name="utilisateur_id"/>
            </list>
        </field>
    </record>

    <record id="action_it_equipement_affectation" model="ir.actions.act_window">
        <field name="name">Historique des affectations</field>
        <field name="res_model">it.equipement.affectation</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_it_equipement_affectation"
              name="Historique des affectations"
              parent="it_parc.menu_it_parc_outils"
              action="action_it_equipement_affectation"
              groups="group_it_manager"
              sequence="50"/>

</odoo>